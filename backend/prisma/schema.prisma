generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  studentId    String   @unique
  email        String?  @unique
  qq           String?  @map("QQ")
  isAdmin      Boolean  @default(false)
  passwordHash String
  nickname     String
  department   String?
  creditScore  Int      @default(100)
  createdAt    DateTime @default(now())

  books        Book[]
  buyReservations  Reservation[] @relation("buyer")
  sellReservations Reservation[] @relation("seller")
  favorites    Favorite[]
}

model Book {
  id            String     @id @default(uuid())
  sellerId      String
  seller        User       @relation(fields: [sellerId], references: [id])
  isbn          String?
  title         String
  author        String?
  publisher     String?
  coverUrl      String?
  price         Float
  originalPrice Float?
  condition     String
  category      String
  tags          String[]
  description   String?
  pickupLocation String?
  status        String     @default("AVAILABLE")
  views         Int        @default(0)
  createdAt     DateTime   @default(now())

  reservations  Reservation[]
  favorites     Favorite[]
}

model Reservation {
  id          String   @id @default(uuid())
  bookId      String
  book        Book     @relation(fields: [bookId], references: [id])
  buyerId     String
  buyer       User     @relation("buyer", fields: [buyerId], references: [id])
  sellerId    String
  seller      User     @relation("seller", fields: [sellerId], references: [id])
  pickupCode  String   @unique
  pickupTime  DateTime?
  status      String   @default("PENDING")
  expiresAt   DateTime
  createdAt   DateTime @default(now())

}


model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, bookId])
}
